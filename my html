<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Untuk Wradista ❤️</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
height:100vh;
background:linear-gradient(135deg,#000000,#3a004d,#ff4da6);
display:flex;
align-items:center;
justify-content:center;
overflow:hidden;
color:white;
}

/* card */

.card{
width:90%;
max-width:420px;
padding:40px;
border-radius:20px;
background:rgba(255,255,255,0.08);
backdrop-filter:blur(12px);
text-align:center;
box-shadow:0 0 30px rgba(255,255,255,0.1);
}

h1{
margin-bottom:10px;
font-size:26px;
}

p{
font-size:15px;
line-height:1.6;
margin-bottom:25px;
}

button{
padding:12px 25px;
border:none;
border-radius:30px;
background:#ff4da6;
color:white;
font-size:14px;
cursor:pointer;
}

button:hover{
transform:scale(1.05);
}

.hidden{
display:none;
}

</style>
</head>

<body>

<div class="card" id="section1">
<h1>Untuk Wradista Farhatus Sanada ❤️</h1>
<p>Aku punya sesuatu yang sangat ingin aku sampaikan ke kamu...</p>
<button onclick="next(1)">Klik di sini</button>
</div>

<div class="card hidden" id="section2">
<h1>Aku Minta Maaf</h1>
<p id="typing"></p>
<button onclick="next(2)">Lanjut</button>
</div>

<div class="card hidden" id="section3">
<h1>Masih mau kasih aku kesempatan?</h1>

<button onclick="yes()">Iya ❤️</button>
<br><br>
<button onclick="alert('Aku akan tetap nunggu kamu ❤️')">Aku pikir dulu</button>

</div>

<script>

function next(num){

document.getElementById("section"+num).classList.add("hidden");

document.getElementById("section"+(num+1)).classList.remove("hidden");

if(num===1){
startTyping();
}

}

const text="distaaa, maaf yah karena telat say hay to u, tapi beneran deh, telat say hay bukan berarti gaa sayangg atauu gaa cintaa, i really love you my girl, my princess.";

let i=0;

function startTyping(){

let speed=40;

function type(){
if(i<text.length){
document.getElementById("typing").innerHTML+=text.charAt(i);
i++;
setTimeout(type,speed);
}
}

type();

}

function yes(){
alert('Terima kasih Wradista. Kamu sangat berarti buat aku.');
}

</script>

</body>
</html>
